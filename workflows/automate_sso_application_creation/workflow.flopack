l"}}},"uuid":"Im4EmpXT9","branches":{},"node":{"key":"comment","data":{"name":"Comment"},"model":{"type":"method","_v":2,"key":"comment","executable":false,"displayed":true,"async":false,"cooperative":false,"mirrored":false,"inlined":false,"dependencies":[],"timeout":90000,"idempotent":false,"monitor":false,"webhook":false,"webhookList":false,"webhookConditions":false,"mobile":false,"hooks":{},"policy":{"error":{"type":"finish"}},"metadata":{"id":null,"name":"Comment","description":"Leave a comment."},"meta":{},"config":null,"partnerChannelKeys":null,"inputs":{"extensible":false,"data":{}},"outputs":{"extensible":false,"data":{}},"runtime":{},"display":{},"comments":{"title":"Public Metadata URL construction","markdown":"The Okta app_id used for the admin/API metadata URL and the id associated with the publicly available metadata URL are different. To handle this use case, a call to retrieve the metadata for the app is done via the admin/API method. The Entity Descriptor inside the body of the response is taken and a segment containing the public metadata 'id' associated with entityID is pulled out. This is then added to the compose containing the close notes portion of the ServiceNow POST body when closing the ticket."}}},"pins":{}},{"joins":{},"address":"root:kernel:control:0.0.1:tryCatch","parents":{"version":{"address":"root:kernel:control:0.0.1","key":"0.0.1","data":{"name":"0.0.1"}},"channel":{"address":"root:kernel:control","key":"control","data":{"name":"control"}}},"uuid":"KVi8T3O9a","branches":{},"node":{"key":"tryCatch","data":{"name":"If Error"},"model":{"type":"method","_v":2,"key":"tryCatch","executable":false,"displayed":true,"async":true,"cooperative":false,"mirrored":false,"inlined":false,"dependencies":[],"timeout":300000,"idempotent":false,"monitor":false,"webhook":false,"webhookList":false,"webhookConditions":false,"mobile":false,"hooks":{},"policy":{"error":{"type":"handler","flo":{"id":"99756d75-fb66-4900-8775-e2027c00326b","uuid":"99756d75-fb6